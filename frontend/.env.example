# Supabase — copy to `.env` (local) and set the same values in Vercel.
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Comma-separated emails that should see the Admin link (UI only; the API
# enforces admin access separately via ADMIN_EMAILS).
VITE_ADMIN_EMAILS=you@example.com
