# ============================================================================
# Copy this file to `.env` for local dev. In Vercel, set the same keys under
# Project → Settings → Environment Variables. Never commit real keys.
# ============================================================================

# ---- Frontend (browser-safe, must start with VITE_) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Comma-separated emails that see the Admin link (UI only).
VITE_ADMIN_EMAILS=you@example.com

# ---- Server / API (keep secret) ----
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — server only
SUPABASE_ANON_KEY=your-anon-public-key
STRIPE_SECRET_KEY=sk_test_xxx                      # enables Stripe payments
STRIPE_WEBHOOK_SECRET=whsec_xxx                    # reliable paid status (Stripe → Webhooks)
ADMIN_EMAILS=you@example.com                       # staff emails (enforced by API)
# PUBLIC_BASE_URL=https://your-app.vercel.app       # optional: Stripe redirect base

# ---- Email notifications (Resend — resend.com) ----
RESEND_API_KEY=re_xxx                              # enables order emails
EMAIL_FROM=PrintUSA <orders@yourdomain.com>        # must be a Resend-verified domain
# BRAND_NAME=PrintUSA                               # optional: name used in emails
