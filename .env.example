# ============================================================================
# SERVER-SIDE env vars — set these in Vercel (Project → Settings → Environment
# Variables) and, for local dev, in a root `.env` file (never commit real keys).
# ============================================================================

# Supabase (server). Same project as the frontend keys.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — server only, never in the browser
SUPABASE_ANON_KEY=your-anon-public-key

# Stripe (payments). From Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_test_xxx

# Staff emails allowed to use the admin dashboard (comma-separated).
ADMIN_EMAILS=you@example.com

# Optional: force the base URL used for Stripe redirects (else derived from request).
# PUBLIC_BASE_URL=https://your-app.vercel.app
