    "start": "node backend/server.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.1",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "multer": "^2.2.0",
    "stripe": "^16.12.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.1",
    "nodemon": "^3.1.0"
  }
}
