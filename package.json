{
  "name": "printing-business-platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace frontend\" \"npm run dev:api\"",
    "dev:api": "nodemon backend/server.js",
